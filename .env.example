# Private Toolbox local environment template.
# Copy to .env.local or export the variables in the shell that starts API/MCP.

# Optional localization tooling.
LOCIZE_API_KEY=

# API server. Bind to 127.0.0.1 for private local use.
PRIVATE_TOOLBOX_API_HOST=127.0.0.1
PRIVATE_TOOLBOX_API_PORT=4317
VITE_PRIVATE_TOOLBOX_API_URL=http://127.0.0.1:4317

# File tool root. All server-side file reads/writes are constrained here.
PRIVATE_TOOLBOX_FILE_ROOT=./output/private-toolbox-files
PRIVATE_TOOLBOX_FILE_OUTPUT_DIR=./output/private-toolbox-files/output
PRIVATE_TOOLBOX_MAX_RENAME_OPERATIONS=500

# Network data sources.
PRIVATE_TOOLBOX_IPPURE_ENABLED=true

# Network rate limiting shared by server-side network tools.
PRIVATE_TOOLBOX_NETWORK_RATE_LIMIT_ENABLED=true
PRIVATE_TOOLBOX_NETWORK_RATE_LIMIT_MAX=60
PRIVATE_TOOLBOX_NETWORK_RATE_LIMIT_WINDOW_MS=60000
PRIVATE_TOOLBOX_NETWORK_RATE_LIMIT_TOOL_OVERRIDES={}
PRIVATE_TOOLBOX_NETWORK_RATE_LIMIT_DATA_SOURCE_OVERRIDES={}
PRIVATE_TOOLBOX_NETWORK_RATE_LIMIT_IPPURE_MAX=60
PRIVATE_TOOLBOX_NETWORK_RATE_LIMIT_IPPURE_WINDOW_MS=60000
PRIVATE_TOOLBOX_NETWORK_RATE_LIMIT_STATE_FILE=./output/private-toolbox-files/rate-limit-state.json

# MCP profile. Use agent-curated for Codex / Claude / OpenClaw-style clients.
PRIVATE_TOOLBOX_MCP_CONFIG=./config/mcp/agent-curated.json
PRIVATE_TOOLBOX_MCP_ENABLE_CORE_TOOLS=true
PRIVATE_TOOLBOX_MCP_ENABLE_SERVER_TOOLS=true
# Compatibility marker only: the MCP server always normalizes HTTP tools to false.
PRIVATE_TOOLBOX_MCP_ENABLE_HTTP_TOOLS=false
PRIVATE_TOOLBOX_MCP_ALLOWED_RISKS=local,network,secret,file-read,file-write
PRIVATE_TOOLBOX_MCP_DISABLED_TOOLS=
PRIVATE_TOOLBOX_MCP_MAX_OUTPUT_BYTES=1048576
PRIVATE_TOOLBOX_MCP_AUDIT_LOG=stderr
